# ═══ IR/BP Workflow 环境变量配置 ═══
# 复制此文件为 .env 并填写你的配置

# ── VL OCR API（用于 BP 文档 OCR 识别）──
# 推荐使用 qwen3-vl 或其他兼容 OpenAI API 的视觉模型
VL_API_BASE=https://YOUR_VL_API_BASE/v1
VL_API_KEY=YOUR_VL_API_KEY
VL_MODEL=qwen3-vl-30b-a3b-instruct

# ── 通知插件配置（可选）──
# 微信 iLink Bot
# WECHAT_BOT_KEY=YOUR_WECHAT_BOT_KEY

# Slack Webhook
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── 搜索引擎配置（可选）──
# SearXNG 本地实例
# SEARXNG_URL=http://localhost:8888

# ── 金融数据 API（可选，推荐使用 WorkBuddy 内置插件）──
# neodata-financial-search skill 已内置，无需额外配置
# NEODATA_API_KEY=YOUR_NEODATA_API_KEY

# ── 向量记忆（可选，用于 ChromaDB）──
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
