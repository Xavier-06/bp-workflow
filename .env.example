# BP Workflow 环境变量配置
# 复制此文件为 .env 并填写你的配置

# ── VL OCR API（用于 BP 文档 OCR 识别）──
# 推荐使用 qwen3-vl 或其他兼容 OpenAI API 的视觉模型
VL_API_BASE=https://YOUR_VL_API_BASE/v1
VL_API_KEY=YOUR_VL_API_KEY
VL_MODEL=qwen3-vl-30b-a3b-instruct

# ── 通知插件配置（可选）──
# 如果使用微信 iLink Bot
# WECHAT_BOT_KEY=YOUR_WECHAT_BOT_KEY

# 如果使用 Slack Webhook
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── 搜索引擎配置（可选）──
# SearXNG 本地实例（如果有的话）
# SEARXNG_URL=http://localhost:8888

# ── 金融数据 API（可选，用于 neodata-financial-search）──
# NEODATA_API_KEY=YOUR_NEODATA_API_KEY
