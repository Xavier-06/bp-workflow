# ═══ IR/BP Workflow 环境变量配置 ═══
# 复制此文件为 .env 并填写你的配置
# 所有变量均有默认值，仅当需要覆盖时才需配置

# ── VL OCR API（BP 文档 OCR 识别）──
# 推荐使用 qwen3-vl 或其他兼容 OpenAI API 的视觉模型
VL_API_BASE=https://YOUR_VL_API_BASE/v1
VL_API_KEY=YOUR_VL_API_KEY
VL_MODEL=qwen3-vl-30b-a3b-instruct

# ── 搜索网关配置 ──
# SearXNG 本地实例（默认 http://127.0.0.1:8888）
# 安装: docker run -d -p 8888:8888 --name searxng searxng/searxng:latest
# SEARXNG_URL=http://127.0.0.1:8888

# DuckDuckGo CLI 二进制名（默认 ddgs，需 pip install duckduckgo-search）
# macOS Homebrew 安装: brew install ddgs
# DDGS_BIN=ddgs

# HTTP 代理（用于 Google/Scrapling 等需要翻墙的搜索层）
# 如不使用代理，留空即可——搜索网关会自动降级到 SearXNG/DDG
# PROXY_URL=http://127.0.0.1:7897

# SSL 证书路径（macOS Homebrew OpenSSL，默认自动探测）
# 如遇 SSL 错误，手动指定：
# SSL_CERT_PATH=/opt/homebrew/etc/openssl@3/cert.pem

# ── NeoData 金融数据（A/HK 股首选数据源）──
# 通过 WorkBuddy neodata-financial-search skill 自动获取 token
# 通常无需手动配置，搜索网关 Layer 0 自动调用
# NEODATA_ENDPOINT=https://copilot.tencent.com/agenttool/v1/neodata

# ── 通知插件配置（可选）──
# 微信 iLink Bot
# WECHAT_BOT_KEY=YOUR_WECHAT_BOT_KEY

# Slack Webhook
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── 向量记忆（可选，用于 ChromaDB）──
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
